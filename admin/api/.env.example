# HTTP server; keep 127.0.0.1 until a domain and HTTPS are ready.
HOST=127.0.0.1
PORT=3000

# Generate with: openssl rand -base64 48
JWT_SECRET=

# Preferred: Server API Key created in CloudBase Console → Environment
# Configuration → API Key Management. It is scoped to this CloudBase environment.
CLOUDBASE_APIKEY=

# Alternative: Tencent Cloud CAM API credentials. Leave these blank when using
# CLOUDBASE_APIKEY. Never use the Tencent Cloud root-account key.
CLOUDBASE_ENV_ID=cloudbase-xxxxxxxx
TENCENTCLOUD_SECRETID=
TENCENTCLOUD_SECRETKEY=

# Used only on the first startup to create the initial super administrator.
# Remove this value once the account has been created.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=
