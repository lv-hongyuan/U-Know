.swipe {
  position: relative;
  overflow: hidden;
  width: 100%;
}

.swipe-actions {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  z-index: 1;
}

.swipe-content {
  position: relative;
  z-index: 2;
  width: 100%;
  background: #ffffff;
  transition: transform 0.2s ease-out;
  box-sizing: border-box;
}

.swipe-content--moving {
  transition: none;
}
