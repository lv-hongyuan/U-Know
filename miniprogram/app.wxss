/**app.wxss**/
page {
  --brand: #ff6b1a;
  --ink: #3d1408;
  --ink-soft: #8b2e0a;
  --lime: #ffb347;
  --bg: #fff6f0;
  --surface: #ffffff;
  --text: #0f1f16;
  --text-secondary: #5c6b60;
  --text-muted: #9aa79e;
  --brand-gradient: linear-gradient(145deg, #ff3b30 0%, #ff6b1a 55%, #ff9500 100%);

  background: var(--bg);
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.page-blank {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
}
