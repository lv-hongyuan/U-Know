.picker-page {
  min-height: 100vh;
  background: #fff6f0;
  box-sizing: border-box;
  padding: 24rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
}

.picker-search {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.picker-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #ffffff;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #0f1f16;
  box-sizing: border-box;
}

.picker-search-btn {
  flex-shrink: 0;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 36rpx;
  background: #ff6b1a;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-step {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.picker-back {
  font-size: 26rpx;
  color: #ff6b1a;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.picker-school-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3d1408;
  margin-bottom: 16rpx;
}

.picker-list {
  flex: 1;
  height: 0;
  background: #ffffff;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f3e8e0;
}

.picker-item:last-child {
  border-bottom: none;
}

.picker-logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  background: #fff6f0;
  flex-shrink: 0;
}

.picker-item-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.picker-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f1f16;
  line-height: 1.35;
}

.picker-item-sub {
  font-size: 22rpx;
  color: #9aa79e;
  line-height: 1.3;
}

.picker-arrow {
  color: #c4b4a8;
  font-size: 36rpx;
  line-height: 1;
}

.picker-empty {
  padding: 80rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.picker-empty-icon {
  width: 120rpx;
  height: 120rpx;
}

.picker-empty-text {
  font-size: 26rpx;
  color: #9aa79e;
}

.picker-loading {
  padding: 48rpx;
  text-align: center;
  font-size: 26rpx;
  color: #9aa79e;
}

.picker-clear {
  margin-top: 24rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #ffffff;
  color: #8b2e0a;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}
