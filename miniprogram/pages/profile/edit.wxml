<view class="page edit-page">
  <!-- 头像昵称手机号 -->
  <view class="edit-card">
    <view class="edit-row edit-row--avatar" bindtap="onTapAvatar">
      <view class="edit-label">头像</view>
      <view class="edit-right">
        <image
          class="edit-avatar"
          src="{{avatarUrl}}"
          mode="aspectFill"
          catchtap="onPreviewAvatar"
        />
        <view class="edit-arrow"></view>
      </view>
    </view>

    <view class="edit-line"></view>

    <view class="edit-row">
      <view class="edit-label">昵称</view>
      <input
        class="edit-input"
        type="nickname"
        maxlength="20"
        placeholder="请输入昵称"
        value="{{nickName}}"
        bindinput="onNickInput"
        bindblur="onSaveNickName"
        confirm-type="done"
        bindconfirm="onSaveNickName"
      />
    </view>

    <view class="edit-line"></view>

    <view class="edit-row" bindtap="onTapPhone">
      <view class="edit-label">手机号</view>
      <view class="edit-right">
        <text class="edit-value">{{phoneNumber || '未绑定'}}</text>
        <view class="edit-arrow"></view>
      </view>
    </view>
  </view>

  <!-- 个人信息 -->
  <view class="section-title">个人信息</view>
  <view class="edit-card">
    <view class="edit-block">
      <view class="edit-block-head">
        <view class="edit-label">简介</view>
        <view class="edit-count">{{bioCount}}/{{bioMax}}</view>
      </view>
      <view class="bio-wrap">
        <textarea
          class="edit-bio"
          maxlength="{{bioMax}}"
          placeholder="介绍一下自己吧"
          value="{{bio}}"
          auto-height
          bindinput="onBioInput"
          bindfocus="onBioFocus"
          bindblur="onBioBlur"
        />
        <view
          class="bio-save {{bioFocused ? 'bio-save--show' : ''}}"
          catchtap="onSaveBio"
        >保存</view>
      </view>
    </view>

    <view class="edit-line edit-line--full"></view>

    <view class="edit-row" bindtap="onTapGender">
      <view class="edit-label">性别</view>
      <view class="edit-right">
        <view class="edit-value-icon">
          <image class="gender-icon" src="/images/gender/{{gender}}.svg" mode="aspectFit" />
          <text class="edit-value">{{genderLabel}}</text>
        </view>
        <view class="edit-arrow"></view>
      </view>
    </view>

    <view class="edit-line"></view>

    <picker
      mode="date"
      value="{{birthday || birthdayEnd}}"
      start="1900-01-01"
      end="{{birthdayEnd}}"
      bindchange="onBirthdayChange"
    >
      <view class="edit-row">
        <view class="edit-label">生日</view>
        <view class="edit-right">
          <text class="edit-value {{birthday ? '' : 'edit-value--placeholder'}}">
            {{birthday || '请选择'}}
          </text>
          <view class="edit-arrow"></view>
        </view>
      </view>
    </picker>

    <view class="edit-line"></view>

    <picker
      mode="region"
      level="city"
      value="{{regionValue}}"
      bindchange="onHometownChange"
    >
      <view class="edit-row">
        <view class="edit-label">家乡</view>
        <view class="edit-right">
          <text class="edit-value {{hometown ? '' : 'edit-value--placeholder'}}">
            {{hometown || '请选择省市'}}
          </text>
          <view class="edit-arrow"></view>
        </view>
      </view>
    </picker>
  </view>

  <view class="logout-btn" bindtap="onTapLogout">注销登录</view>

  <!-- 更换头像 -->
  <view class="sheet-mask" wx:if="{{showAvatarSheet}}" catchtouchmove="noop" bindtap="onCloseAvatarSheet">
    <view class="sheet" catchtap="noop">
      <view class="sheet-title">更换头像</view>
      <view class="sheet-item sheet-item--action">
        <text>使用微信头像</text>
        <button
          class="sheet-ghost-btn"
          open-type="chooseAvatar"
          bindchooseavatar="onChooseWechatAvatar"
        ></button>
      </view>
      <view class="sheet-item" bindtap="onPickCamera">拍摄</view>
      <view class="sheet-item sheet-item--last" bindtap="onPickAlbum">从相册选择</view>
      <view class="sheet-cancel" bindtap="onCloseAvatarSheet">取消</view>
    </view>
  </view>

  <!-- 选择性别 -->
  <view class="sheet-mask" wx:if="{{showGenderSheet}}" catchtouchmove="noop" bindtap="onCloseGenderSheet">
    <view class="sheet" catchtap="noop">
      <view class="gender-sheet">
        <view class="gender-sheet-head">
          <view class="gender-sheet-cancel" bindtap="onCloseGenderSheet">取消</view>
          <view class="gender-sheet-title">选择性别</view>
          <view class="gender-sheet-save" bindtap="onSaveGender">保存</view>
        </view>
        <view
          class="gender-sheet-item {{draftGender === 'male' ? 'gender-sheet-item--active' : ''}}"
          data-gender="male"
          bindtap="onPickGender"
        >
          <image class="gender-icon" src="/images/gender/male.svg" mode="aspectFit" />
          <text>男</text>
          <view class="gender-check" wx:if="{{draftGender === 'male'}}"></view>
        </view>
        <view
          class="gender-sheet-item {{draftGender === 'female' ? 'gender-sheet-item--active' : ''}}"
          data-gender="female"
          bindtap="onPickGender"
        >
          <image class="gender-icon" src="/images/gender/female.svg" mode="aspectFit" />
          <text>女</text>
          <view class="gender-check" wx:if="{{draftGender === 'female'}}"></view>
        </view>
        <view
          class="gender-sheet-item gender-sheet-item--last {{draftGender === 'secret' ? 'gender-sheet-item--active' : ''}}"
          data-gender="secret"
          bindtap="onPickGender"
        >
          <image class="gender-icon" src="/images/gender/secret.svg" mode="aspectFit" />
          <text>保密</text>
          <view class="gender-check" wx:if="{{draftGender === 'secret'}}"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 更换手机号 -->
  <view class="sheet-mask" wx:if="{{showPhoneSheet}}" catchtouchmove="noop" bindtap="onClosePhoneSheet">
    <view class="sheet" catchtap="noop">
      <view class="phone-sheet">
        <view class="login-handle"></view>
        <view class="phone-sheet-title">更换手机号</view>
        <view class="phone-sheet-desc">将获取你微信绑定的手机号</view>
        <button
          class="phone-sheet-btn"
          open-type="getPhoneNumber"
          bindgetphonenumber="onChangePhone"
          loading="{{saving}}"
          disabled="{{saving}}"
        >
          授权微信手机号
        </button>
        <view class="sheet-cancel sheet-cancel--inline" bindtap="onClosePhoneSheet">取消</view>
      </view>
    </view>
  </view>

  <!-- 头像预览 -->
  <view class="avatar-preview" wx:if="{{showAvatarPreview}}" catchtouchmove="noop">
    <view class="avatar-preview-close" bindtap="onCloseAvatarPreview">关闭</view>
    <image class="avatar-preview-img" src="{{avatarUrl}}" mode="aspectFit" bindtap="onCloseAvatarPreview" />
    <view class="avatar-preview-footer">
      <view class="avatar-preview-save" bindtap="onSaveAvatarToAlbum">保存头像</view>
    </view>
  </view>

  <!-- 注销确认 -->
  <view class="sheet-mask sheet-mask--center" wx:if="{{showLogoutConfirm}}" catchtouchmove="noop" bindtap="onCloseLogoutConfirm">
    <view class="confirm-dialog" catchtap="noop">
      <view class="confirm-title">确认注销登录？</view>
      <view class="confirm-desc">退出后需重新授权手机号登录</view>
      <view class="confirm-actions">
        <view class="confirm-btn confirm-btn--cancel" bindtap="onCloseLogoutConfirm">取消</view>
        <view class="confirm-btn confirm-btn--danger" bindtap="onConfirmLogout">确认退出</view>
      </view>
    </view>
  </view>
</view>
