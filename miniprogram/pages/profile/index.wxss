.profile-page {
  padding: 32rpx 32rpx 0;
}

.profile-header {
  display: flex;
  align-items: center;
  padding: 40rpx 36rpx;
  background: linear-gradient(145deg, #0a2e1a 0%, #14522e 55%, #028527 100%);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(10, 46, 26, 0.18);
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #d8ddd8;
  border: 4rpx solid rgba(255, 255, 255, 0.35);
  flex-shrink: 0;
}

.profile-avatar--guest {
  opacity: 0.92;
  filter: grayscale(0.15);
}

.profile-meta {
  margin-left: 28rpx;
  min-width: 0;
  flex: 1;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.64);
}

.login-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(10, 46, 26, 0.55);
  display: flex;
  align-items: flex-end;
}

.login-sheet {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  background: #f3f6f2;
  border-radius: 40rpx 40rpx 0 0;
}

.login-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 28rpx;
  border-radius: 4rpx;
  background: rgba(15, 31, 22, 0.18);
}

.login-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f1f16;
  text-align: center;
}

.login-desc {
  margin-top: 12rpx;
  margin-bottom: 40rpx;
  font-size: 24rpx;
  color: #5c6b60;
  text-align: center;
}

.login-submit {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  background: #028527;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
}

.login-submit::after {
  border: none;
}

.login-submit[disabled] {
  opacity: 0.7;
}

.login-cancel {
  margin-top: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #5c6b60;
  padding: 16rpx;
}
