.profile-page {
  height: 100vh;
  padding: 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: #fff6f0;
}

.profile-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
}

.profile-top {
  padding: 32rpx 32rpx 0;
}

.profile-header {
  position: relative;
  display: flex;
  align-items: center;
  padding: 48rpx 36rpx 40rpx;
  background: linear-gradient(145deg, #3d1408 0%, #8b2e0a 55%, #FF6B1A 100%);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(61, 20, 8, 0.18);
  overflow: hidden;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #d8ddd8;
  border: 4rpx solid rgba(255, 255, 255, 0.35);
  flex-shrink: 0;
}

.profile-avatar--guest {
  opacity: 0.92;
  filter: grayscale(0.15);
}

.profile-meta {
  margin-left: 28rpx;
  margin-right: 72rpx;
  min-width: 0;
  flex: 1;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-school {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  max-width: 78%;
  height: 44rpx;
  padding: 0 16rpx 0 20rpx;
  border-radius: 0 0 18rpx 0;
  background: rgba(255, 255, 255, 0.2);
  border-right: 1rpx solid rgba(255, 255, 255, 0.22);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.22);
  box-sizing: border-box;
}

.profile-school-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  border-radius: 6rpx;
  background: #ffffff;
}

.profile-school-text {
  min-width: 0;
  font-size: 20rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-id {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
  line-height: 1.35;
}

.profile-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.64);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-word;
}

.profile-sub--muted {
  color: rgba(255, 255, 255, 0.42);
}

.profile-settings {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-settings-icon {
  width: 36rpx;
  height: 36rpx;
}

.profile-stats {
  display: flex;
  align-items: stretch;
  margin-top: 24rpx;
  padding: 28rpx 12rpx;
  background: #ffffff;
  border-radius: 28rpx;
}

.profile-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 0;
  padding: 0 8rpx;
}

.profile-stat-num {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f1f16;
  line-height: 1.2;
}

.profile-stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #5c6b60;
  text-align: center;
  line-height: 1.3;
}

.profile-content {
  margin-top: 20rpx;
}

.profile-tabs {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  width: fit-content;
  max-width: calc(100% - 64rpx);
  gap: 4rpx;
  margin: 0 32rpx;
  padding: 8rpx 10rpx 14rpx;
  background: linear-gradient(180deg, #ffdcc4 0%, #ffe8d9 42%, #fff6f0 100%);
  border-radius: 28rpx 28rpx 0 28rpx;
  box-sizing: border-box;
}

.profile-tab {
  position: relative;
  min-width: 120rpx;
  min-height: 64rpx;
  padding: 0 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #9a6b52;
  font-weight: 600;
  line-height: 1;
  border-radius: 999rpx;
  background: transparent;
  box-sizing: border-box;
}

.profile-tab--active {
  color: #ffffff;
  font-weight: 700;
  background: linear-gradient(135deg, #ff6b1a 0%, #ff3b30 100%);
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 26, 0.28);
}

.profile-filters {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 32rpx 16rpx;
}

.profile-filter {
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-height: 52rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  color: #9a6b52;
  font-weight: 600;
  border-radius: 999rpx;
  background: transparent;
  box-sizing: border-box;
}

.profile-filter--active {
  color: #3d1408;
  background: rgba(255, 107, 26, 0.12);
}

.profile-filter-lock {
  width: 22rpx;
  height: 22rpx;
}

.profile-drafts {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 12rpx 24rpx;
  box-sizing: border-box;
}

.profile-draft-card {
  width: calc(50% - 6rpx);
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.profile-draft-cover {
  width: 100%;
  padding-bottom: 125%;
  position: relative;
  background: #e8ece8;
}

.profile-draft-image {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.profile-draft-image--text {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
  background: linear-gradient(145deg, #3d1408 0%, #8b2e0a 55%, #FF6B1A 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.profile-draft-title {
  padding: 14rpx 12rpx 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #0f1f16;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.profile-empty,
.profile-guest {
  padding: 64rpx 24rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8a968c;
}

.profile-scroll-pad {
  height: calc(160rpx + env(safe-area-inset-bottom));
}

.login-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10000;
  background: rgba(10, 46, 26, 0.55);
  display: flex;
  align-items: flex-end;
}

.login-sheet {
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  background: #fff6f0;
  border-radius: 40rpx 40rpx 0 0;
}

.login-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 28rpx;
  border-radius: 4rpx;
  background: rgba(15, 31, 22, 0.18);
}

.login-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f1f16;
  text-align: center;
}

.login-desc {
  margin-top: 12rpx;
  margin-bottom: 40rpx;
  font-size: 24rpx;
  color: #5c6b60;
  text-align: center;
}

.login-submit {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  background: #FF6B1A;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
}

.login-submit::after {
  border: none;
}

.login-submit[disabled] {
  opacity: 0.7;
}

.login-cancel {
  margin-top: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #5c6b60;
  padding: 16rpx;
}
