.settings-page {
  padding: 32rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
}

.settings-card {
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
}

.settings-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 112rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.settings-label {
  font-size: 30rpx;
  color: #0f1f16;
  font-weight: 600;
}

.settings-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-width: 0;
}

.settings-value {
  font-size: 28rpx;
  color: #5c6b60;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.settings-arrow {
  width: 16rpx;
  height: 16rpx;
  margin-left: 16rpx;
  border-top: 4rpx solid #c2cbc4;
  border-right: 4rpx solid #c2cbc4;
  transform: rotate(45deg);
  flex-shrink: 0;
}

.settings-line {
  height: 1rpx;
  margin-left: 32rpx;
  background: #edf1ec;
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(10, 46, 26, 0.55);
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.locale-sheet {
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
}

.locale-sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  padding: 0 28rpx;
  border-bottom: 1rpx solid #edf1ec;
  box-sizing: border-box;
}

.locale-sheet-cancel {
  width: 80rpx;
  font-size: 28rpx;
  color: #5c6b60;
}

.locale-sheet-title {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f1f16;
}

.locale-sheet-spacer {
  width: 80rpx;
}

.locale-sheet-item {
  position: relative;
  display: flex;
  align-items: center;
  height: 104rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #0f1f16;
  border-top: 1rpx solid #edf1ec;
  box-sizing: border-box;
}

.locale-sheet-item--active {
  color: #028527;
}

.locale-sheet-item--last {
  border-radius: 0 0 28rpx 28rpx;
}

.locale-check {
  margin-left: auto;
  width: 28rpx;
  height: 14rpx;
  border-left: 4rpx solid #028527;
  border-bottom: 4rpx solid #028527;
  transform: rotate(-45deg);
  margin-bottom: 8rpx;
}
