page {
  height: 100%;
  background: #fff6f0;
}

/* 覆盖 app.wxss .page 的 tabBar 底部留白，避免输入栏下方空洞 */
.room-page {
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #fff6f0;
  box-sizing: border-box;
  overflow: hidden;
  padding-bottom: 0;
}

.room-nav {
  flex-shrink: 0;
  background: #fff6f0;
  border-bottom: 1rpx solid rgba(61, 20, 8, 0.06);
}

.room-nav-inner {
  display: flex;
  align-items: center;
  padding: 0 12rpx 0 8rpx;
  box-sizing: border-box;
}

.room-nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.room-nav-back-icon {
  width: 40rpx;
  height: 40rpx;
}

.room-nav-peer {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
  flex: 1;
  margin-right: 200rpx;
}

.room-nav-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #e8ece8;
  flex-shrink: 0;
}

.room-nav-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #3d1408;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
}

.room-scroll-inner {
  box-sizing: border-box;
  padding: 16rpx 20rpx 24rpx;
}

.room-top-space {
  width: 100%;
  flex-shrink: 0;
}

.room-msgs {
  width: 100%;
}

.room-loading {
  text-align: center;
  font-size: 24rpx;
  color: #9a6b52;
  padding: 12rpx;
}

.room-time {
  display: flex;
  justify-content: center;
  padding: 8rpx 0 20rpx;
}

.room-time-text {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #9a6b52;
  background: rgba(61, 20, 8, 0.06);
}

.room-recalled {
  text-align: center;
  padding: 16rpx;
  font-size: 22rpx;
  color: #9a6b52;
}

.room-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  transition: background-color 160ms ease, box-shadow 160ms ease;
}

.room-row--selected {
  background: rgba(255, 107, 26, 0.1);
  box-shadow: 0 0 0 8rpx rgba(255, 107, 26, 0.1);
}

.room-row--mine {
  flex-direction: row;
  justify-content: flex-end;
}

.room-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #e8ece8;
  flex-shrink: 0;
}

.room-bubble-wrap {
  max-width: 70%;
  min-width: 0;
}

.room-quote {
  margin-bottom: 10rpx;
  padding: 8rpx 12rpx;
  border-radius: 10rpx;
  background: rgba(61, 20, 8, 0.06);
  display: flex;
  align-items: center;
  gap: 10rpx;
  border-left: 4rpx solid rgba(255, 107, 26, 0.55);
}

.room-bubble--mine .room-quote {
  background: rgba(255, 255, 255, 0.18);
  border-left-color: rgba(255, 255, 255, 0.75);
}

.room-quote-thumb {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #e8d5c8;
  overflow: hidden;
  position: relative;
}

.room-quote-thumb-img {
  width: 100%;
  height: 100%;
}

.room-quote-thumb--video {
  background: #3d1408;
}

.room-quote-thumb--ph {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(61, 20, 8, 0.08);
}

.room-bubble--mine .room-quote-thumb--ph {
  background: rgba(255, 255, 255, 0.15);
}

.room-quote-ph-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.65;
}

.room-quote-play {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 0;
  height: 0;
  margin-left: -6rpx;
  margin-top: -10rpx;
  border-style: solid;
  border-width: 10rpx 0 10rpx 16rpx;
  border-color: transparent transparent transparent rgba(255, 255, 255, 0.92);
  pointer-events: none;
}

.room-quote-play--sm {
  margin-left: -5rpx;
  margin-top: -8rpx;
  border-width: 8rpx 0 8rpx 12rpx;
}

.room-quote-text {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.35;
  color: #9a6b52;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.room-bubble--mine .room-quote-text {
  color: #ffffff;
  opacity: 0.96;
}

.room-bubble {
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.45;
  color: #3d1408;
  background: #ffffff;
  word-break: break-word;
  max-width: 100%;
  box-sizing: border-box;
}

.room-bubble-text {
  display: block;
  word-break: break-word;
}

.room-row--mine .room-bubble,
.room-bubble--mine {
  background: linear-gradient(135deg, #ff6b1a 0%, #ff3b30 100%);
  color: #ffffff;
}

.room-media-image {
  max-width: 420rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #e8ece8;
}

.room-media-pending {
  position: relative;
  width: 360rpx;
  height: 360rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #e8d5c8;
}

.room-media-pending--video {
  width: 420rpx;
  height: 320rpx;
}

.room-media-pending-img {
  width: 100%;
  height: 100%;
}

.room-media-pending-video {
  width: 100%;
  height: 100%;
  background: #3d1408;
}

.room-media-pending-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(61, 20, 8, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 12rpx;
}

.room-progress {
  width: 70%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.room-progress-track {
  width: 100%;
  height: 12rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.28);
  overflow: hidden;
}

.room-progress-bar {
  height: 100%;
  border-radius: 6rpx;
  background: #ffffff;
}

.room-progress-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 600;
}

.room-media-failed {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 600;
}

.room-media-video {
  width: 420rpx;
  height: 320rpx;
  border-radius: 16rpx;
  background: #1a0a06;
}

.room-post-card {
  width: 420rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid rgba(61, 20, 8, 0.08);
}

.room-post-cover {
  width: 100%;
  height: 220rpx;
  background: #e8ece8;
  display: block;
}

.room-post-body {
  padding: 16rpx 18rpx 18rpx;
}

.room-post-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #3d1408;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.room-post-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
}

.room-post-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #e8ece8;
  flex-shrink: 0;
}

.room-post-nick {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: #9a6b52;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-post-like {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: #9a6b52;
  flex-shrink: 0;
}

.room-post-like-icon {
  width: 28rpx;
  height: 28rpx;
}

.room-history-card {
  width: 420rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid rgba(61, 20, 8, 0.08);
  box-sizing: border-box;
}

.room-history-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #3d1408;
  margin-bottom: 10rpx;
}

.room-history-line {
  display: block;
  font-size: 24rpx;
  line-height: 1.45;
  color: #9a6b52;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-composer {
  position: relative;
  z-index: 20;
  flex-shrink: 0;
  background: #ffffff;
  border-top: 1rpx solid rgba(61, 20, 8, 0.06);
  box-sizing: border-box;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.room-composer--kb {
  padding-bottom: 0;
}

.room-quote-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  background: #ffe8d9;
}

.room-quote-bar-thumb {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #e8d5c8;
  overflow: hidden;
  position: relative;
}

.room-quote-bar-thumb--video {
  background: #3d1408;
}

.room-quote-bar-thumb-video {
  width: 100%;
  height: 100%;
}

.room-quote-bar-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: #9a6b52;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-quote-bar-close {
  width: 48rpx;
  height: 48rpx;
  text-align: center;
  line-height: 48rpx;
  font-size: 32rpx;
  color: #9a6b52;
}

.room-composer-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 16rpx;
}

.room-tool {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: #fff6f0;
  color: #ff6b1a;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.room-input-wrap {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  border-radius: 34rpx;
  background: #fff6f0;
  display: flex;
  align-items: center;
  padding: 0 12rpx 0 20rpx;
  box-sizing: border-box;
}

.room-input {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  font-size: 28rpx;
  color: #3d1408;
}

.room-input-plus {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #ff6b1a;
  flex-shrink: 0;
  line-height: 1;
}

.room-send {
  min-width: 100rpx;
  height: 64rpx;
  padding: 0 20rpx;
  border-radius: 32rpx;
  background: #e8d5c8;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.room-send--on {
  background: #ff6b1a;
}

.room-emoji {
  display: flex;
  flex-wrap: wrap;
  padding: 8rpx 16rpx 20rpx;
  max-height: 280rpx;
  overflow-y: auto;
}

.room-emoji-item {
  width: 12.5%;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.room-plus {
  display: flex;
  padding: 8rpx 48rpx 28rpx;
  gap: 48rpx;
  justify-content: flex-start;
}

.room-plus-item {
  width: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #5c6b60;
}

.room-plus-icon-wrap {
  width: 104rpx;
  height: 104rpx;
  border-radius: 24rpx;
  background: #fff6f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.room-plus-icon {
  width: 52rpx;
  height: 52rpx;
}

.room-pop-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: transparent;
}

.room-pop-menu {
  position: fixed;
  z-index: 1001;
  transform: translate(-50%, calc(-100% - 16rpx));
  display: flex;
  flex-wrap: wrap;
  max-width: 520rpx;
  padding: 8rpx 10rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(61, 20, 8, 0.16);
  gap: 4rpx;
}

.room-pop-arrow {
  position: absolute;
  bottom: -8rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 6rpx;
  background: #ffffff;
  transform: translateX(-50%) rotate(45deg);
  box-shadow: 4rpx 4rpx 8rpx rgba(61, 20, 8, 0.08);
}

.room-pop-item {
  padding: 14rpx 18rpx;
  font-size: 26rpx;
  color: #3d1408;
  font-weight: 600;
  white-space: nowrap;
}

.room-pop-item--disabled {
  color: #c4b0a4;
}

.room-pop-item--danger {
  color: #ff3b30;
}
