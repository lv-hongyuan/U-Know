.compose-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f3f6f2;
  box-sizing: border-box;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.compose-body {
  flex: 1;
  padding: 24rpx 32rpx;
}

.compose-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.compose-image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.compose-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #d8ddd8;
}

.compose-image-del {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 20rpx;
  background: rgba(15, 31, 22, 0.72);
  color: #ffffff;
  font-size: 28rpx;
}

.compose-image-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 2rpx dashed #c2cbc4;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.compose-image-add-plus {
  font-size: 48rpx;
  color: #8a968c;
  line-height: 1;
}

.compose-image-add-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a968c;
}

.compose-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 72rpx;
}

.compose-title {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #0f1f16;
  /* 加粗中文在 input 左侧易被裁切，留出安全边距 */
  padding: 0 8rpx 0 12rpx;
  box-sizing: border-box;
}

.compose-title-count {
  flex-shrink: 0;
  line-height: 72rpx;
}

.compose-count {
  font-size: 22rpx;
  color: #8a968c;
  text-align: right;
}

.compose-content {
  width: 100%;
  min-height: 320rpx;
  margin-top: 12rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #0f1f16;
  line-height: 1.6;
  box-sizing: border-box;
}

.compose-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.compose-topic-btn {
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  background: #e8f5e9;
  color: #028527;
  font-size: 24rpx;
  font-weight: 600;
}

.compose-topics {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.compose-topic-chip {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #028527;
  font-size: 24rpx;
}

.compose-field {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.compose-field-label {
  font-size: 28rpx;
  color: #0f1f16;
  font-weight: 600;
}

.compose-field-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.compose-field-value {
  font-size: 28rpx;
  color: #5c6b60;
}

.compose-field-arrow {
  font-size: 32rpx;
  color: #c2cbc4;
  line-height: 1;
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(10, 46, 26, 0.55);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.sheet {
  width: 100%;
  box-sizing: border-box;
  padding: 12rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: transparent;
}

.vis-sheet {
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
}

.vis-sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  padding: 0 28rpx;
  border-bottom: 1rpx solid #edf1ec;
  box-sizing: border-box;
}

.vis-sheet-cancel {
  width: 80rpx;
  font-size: 28rpx;
  color: #5c6b60;
}

.vis-sheet-title {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f1f16;
}

.vis-sheet-spacer {
  width: 80rpx;
}

.vis-sheet-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 120rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #edf1ec;
  box-sizing: border-box;
}

.vis-sheet-item--active {
  color: #028527;
}

.vis-sheet-item--last {
  border-radius: 0 0 28rpx 28rpx;
}

.vis-sheet-item-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.vis-sheet-item-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f1f16;
}

.vis-sheet-item--active .vis-sheet-item-label {
  color: #028527;
}

.vis-sheet-item-desc {
  font-size: 22rpx;
  color: #8a968c;
}

.vis-check {
  flex-shrink: 0;
  width: 28rpx;
  height: 14rpx;
  border-left: 4rpx solid #028527;
  border-bottom: 4rpx solid #028527;
  transform: rotate(-45deg);
  margin-bottom: 8rpx;
}

.compose-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(10, 46, 26, 0.06);
  box-sizing: border-box;
}

.compose-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  background: #028527;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.compose-btn--ghost {
  background: #f3f6f2;
  color: #5c6b60;
}
