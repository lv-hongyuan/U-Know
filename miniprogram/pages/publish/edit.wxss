.edit-media-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #0a2e1a;
  box-sizing: border-box;
}

.edit-media-preview {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 0;
  padding: 24rpx;
  box-sizing: border-box;
}

.edit-media-img {
  width: 100%;
  height: 100%;
}

.edit-media-tools {
  background: #f3f6f2;
  border-radius: 32rpx 32rpx 0 0;
  padding: 8rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
}

.edit-media-tabs {
  display: flex;
  justify-content: center;
  padding: 16rpx 0 24rpx;
}

.edit-media-tab {
  padding: 12rpx 28rpx;
  font-size: 28rpx;
  color: #5c6b60;
  font-weight: 600;
}

.edit-media-tab--active {
  color: #028527;
  position: relative;
}

.edit-media-tab--active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 40rpx;
  height: 6rpx;
  margin-left: -20rpx;
  border-radius: 3rpx;
  background: #028527;
}

.edit-media-actions {
  display: flex;
  gap: 16rpx;
}

.edit-media-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  background: #028527;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.edit-media-btn--ghost {
  background: #ffffff;
  color: #0f1f16;
  border: 2rpx solid #d8e0d8;
  line-height: 84rpx;
  box-sizing: border-box;
}
