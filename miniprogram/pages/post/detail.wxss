.detail-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #fff6f0;
  box-sizing: border-box;
  padding-bottom: 0;
}

.detail-page--loading {
  align-items: center;
  justify-content: center;
}

.detail-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
}

.detail-author {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 28rpx 12rpx;
}

.detail-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: #d8ddd8;
  flex-shrink: 0;
}

.detail-nick {
  flex: 0 1 auto;
  min-width: 0;
  max-width: 40%;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f1f16;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-school-tag {
  flex-shrink: 1;
  min-width: 0;
  max-width: 28%;
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  background: rgba(255, 107, 26, 0.12);
  color: #ff6b1a;
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.detail-follow {
  flex-shrink: 0;
  margin-left: auto;
  min-width: 112rpx;
  height: 52rpx;
  padding: 0 22rpx;
  border-radius: 26rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
  background: #FF6B1A;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.detail-follow--on {
  color: #5c6b60;
  background: #eef1ec;
}

.detail-follow--busy {
  opacity: 0.6;
  pointer-events: none;
}

.detail-menu {
  width: 64rpx;
  height: 64rpx;
  margin-left: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.detail-menu-icon {
  width: 40rpx;
  height: 40rpx;
}

.detail-swiper {
  width: 100%;
  background: #0f1f16;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.detail-text-cover {
  margin: 0 28rpx;
  min-height: 280rpx;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #3d1408 0%, #8b2e0a 55%, #FF6B1A 100%);
}

.detail-text-cover-title {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
  text-align: center;
}

.detail-body {
  padding: 24rpx 28rpx 8rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f1f16;
  line-height: 1.4;
}

.detail-content {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #0f1f16;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-word;
}

.detail-topics {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.detail-topic {
  font-size: 24rpx;
  color: #ff6b1a;
  font-weight: 600;
}

.detail-topic--school {
  color: #8b2e0a;
  background: rgba(255, 107, 26, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.detail-views {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #8a968c;
}

.detail-views-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.55;
  /* eye.svg 为白色，详情浅底上调暗 */
  filter: invert(1) brightness(0.45);
}

.detail-comments-head {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  padding: 28rpx 28rpx 8rpx;
}

.detail-comments-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f1f16;
}

.detail-comments-count {
  font-size: 24rpx;
  color: #8a968c;
}

.detail-comment-card {
  margin: 0 20rpx 16rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.detail-comment-card--focus {
  background: #eef6ea;
  transition: background-color 0.35s ease;
}

.detail-reply--focus {
  border-radius: 12rpx;
  background: #eef6ea;
  margin: 0 -8rpx;
  padding: 8rpx;
  box-sizing: border-box;
  transition: background-color 0.35s ease;
}

.detail-comment {
  display: flex;
  gap: 16rpx;
  padding: 0;
}

.detail-comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #d8ddd8;
  flex-shrink: 0;
}

.detail-comment-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-comment-nick {
  font-size: 24rpx;
  font-weight: 600;
  color: #5c6b60;
}

.detail-comment-text {
  font-size: 28rpx;
  color: #0f1f16;
  line-height: 1.5;
  word-break: break-word;
}

.detail-comment-image,
.detail-reply-image {
  width: 220rpx;
  max-width: 100%;
  border-radius: 12rpx;
  margin-top: 8rpx;
  background: #eef1ec;
}

.detail-comment-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 8rpx;
}

.detail-comment-meta--reply {
  margin-top: 6rpx;
}

.detail-comment-meta-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-width: 0;
}

.detail-comment-time {
  font-size: 20rpx;
  color: #8a968c;
  flex-shrink: 0;
}

.detail-comment-action {
  font-size: 22rpx;
  color: #8a968c;
  flex-shrink: 0;
}

.detail-comment-like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.detail-comment-like-icon {
  width: 28rpx;
  height: 28rpx;
}

.detail-comment-like-num {
  font-size: 20rpx;
  color: #8a968c;
  min-width: 20rpx;
}

.detail-comment-like--reply .detail-comment-like-icon {
  width: 24rpx;
  height: 24rpx;
}

.detail-comment-like--reply .detail-comment-like-num {
  font-size: 18rpx;
}

.detail-replies {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(15, 31, 22, 0.06);
}

.detail-reply {
  display: flex;
  gap: 12rpx;
}

.detail-reply + .detail-reply {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(15, 31, 22, 0.06);
}

.detail-reply-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #d8ddd8;
  flex-shrink: 0;
}

.detail-reply-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-reply-head {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6rpx;
  line-height: 1.3;
}

.detail-reply-nick {
  font-size: 20rpx;
  font-weight: 600;
  color: #5c6b60;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-reply-label {
  font-size: 20rpx;
  color: #8a968c;
  flex-shrink: 0;
}

.detail-reply-text {
  font-size: 24rpx;
  color: #0f1f16;
  line-height: 1.5;
  word-break: break-word;
}

.detail-reply-action {
  font-size: 20rpx;
  color: #8a968c;
  flex-shrink: 0;
}

.detail-replies-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-top: 12rpx;
  margin-left: -36rpx;
  width: calc(100% + 72rpx);
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(15, 31, 22, 0.06);
  box-sizing: border-box;
}

.detail-replies-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 22rpx;
  color: #5c6b60;
  font-weight: 500;
  margin-right: 40px;
}

.detail-replies-toggle-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.detail-empty,
.detail-status {
  padding: 40rpx 28rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8a968c;
}

.detail-scroll-pad {
  height: calc(140rpx + env(safe-area-inset-bottom));
}

.detail-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx calc(12rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(10, 46, 26, 0.06);
  box-sizing: border-box;
}

.detail-action {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
  gap: 4rpx;
  padding-right: 4rpx;
}

.detail-action-icon {
  width: 50rpx;
  height: 50rpx;
  flex-shrink: 0;
  display: block;
}

.detail-action-icon--star {
  width: 56rpx;
  height: 56rpx;
}

.detail-action-num {
  font-size: 22rpx;
  color: #5c6b60;
  line-height: 1;
  min-width: 16rpx;
}

.detail-input-wrap {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  margin-left: 16rpx;
  padding: 0 24rpx 0 20rpx;
  border-radius: 36rpx;
  background: #fff6f0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-input-edit {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  opacity: 0.7;
}

.detail-input-fake {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  color: #8a968c;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-input-fake--filled {
  color: #0f1f16;
}

.composer-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(10, 46, 26, 0.55);
  display: flex;
  align-items: flex-end;
}

.composer-sheet {
  width: 100%;
  min-height: 42vh;
  max-height: 72vh;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.composer-textarea {
  width: 100%;
  min-height: 180rpx;
  max-height: 320rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #fff6f0;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #0f1f16;
  line-height: 1.6;
}

.composer-image-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-top: 16rpx;
}

.composer-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: #eef1ec;
}

.composer-image-del {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: rgba(15, 31, 22, 0.72);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

.composer-emoji-panel {
  width: 100%;
  margin-top: 16rpx;
  white-space: nowrap;
}

.composer-emoji {
  display: inline-block;
  padding: 8rpx 12rpx;
  font-size: 40rpx;
  line-height: 1;
}

.composer-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
}

.composer-tools {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.composer-tool {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: #fff6f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.composer-tool-icon {
  width: 36rpx;
  height: 36rpx;
}

.composer-tool-emoji {
  font-size: 36rpx;
  line-height: 1;
}

.composer-send {
  min-width: 120rpx;
  height: 64rpx;
  padding: 0 28rpx;
  border-radius: 32rpx;
  background: #e8f0e8;
  color: #8a968c;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.composer-send--on {
  background: #e8f5e9;
  color: #FF6B1A;
}
