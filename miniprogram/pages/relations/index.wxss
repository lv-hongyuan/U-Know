.relations-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #ffffff;
  box-sizing: border-box;
}

.relations-tabs {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #edf1ec;
  background: #ffffff;
}

.relations-tab {
  position: relative;
  padding: 28rpx 8rpx;
  font-size: 30rpx;
  color: #5c6b60;
  font-weight: 600;
}

.relations-tab--active {
  color: #0f1f16;
  font-weight: 700;
}

.relations-tab--active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 48rpx;
  height: 6rpx;
  margin-left: -24rpx;
  border-radius: 3rpx;
  background: #028527;
}

.relations-search {
  padding: 20rpx 32rpx 8rpx;
}

.relations-search-inner {
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f3f6f2;
  border-radius: 36rpx;
  box-sizing: border-box;
}

.relations-search-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 16rpx;
  border: 3rpx solid #8a968c;
  border-radius: 50%;
  position: relative;
  flex-shrink: 0;
  box-sizing: border-box;
}

.relations-search-icon::after {
  content: "";
  position: absolute;
  right: -8rpx;
  bottom: -6rpx;
  width: 12rpx;
  height: 3rpx;
  background: #8a968c;
  transform: rotate(45deg);
  border-radius: 2rpx;
}

.relations-search-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  font-size: 28rpx;
  color: #0f1f16;
}

.relations-search-clear {
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  font-size: 32rpx;
  color: #8a968c;
  flex-shrink: 0;
}

.relations-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx 8rpx;
}

.relations-count {
  font-size: 26rpx;
  color: #5c6b60;
  font-weight: 600;
}

.relations-sort {
  font-size: 24rpx;
  color: #8a968c;
}

.relations-list {
  flex: 1;
  height: 0;
  padding: 8rpx 0 calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.relations-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
}

.relations-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: #d8ddd8;
  flex-shrink: 0;
}

.relations-meta {
  flex: 1;
  min-width: 0;
  margin: 0 20rpx;
}

.relations-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f1f16;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.relations-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5c6b60;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.relations-desc--muted {
  color: #a0aaa3;
}

.relations-action {
  flex-shrink: 0;
  min-width: 140rpx;
  height: 56rpx;
  padding: 0 22rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #0f1f16;
  border: 2rpx solid #d8e0d8;
  border-radius: 28rpx;
  box-sizing: border-box;
}

.relations-action--primary {
  color: #ffffff;
  background: #028527;
  border-color: #028527;
}

.relations-action--mutual {
  color: #5c6b60;
}

.relations-empty,
.relations-loading,
.relations-end {
  padding: 80rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8a968c;
}

.relations-end {
  padding: 24rpx 32rpx 48rpx;
}
