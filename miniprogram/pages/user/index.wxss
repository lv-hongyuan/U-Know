.user-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: #fff6f0;
}

.user-page--loading {
  align-items: center;
  justify-content: center;
}

.user-loading {
  font-size: 26rpx;
  color: #8a968c;
}

.user-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
}

.user-top {
  padding: 24rpx 32rpx 8rpx;
}

.user-header {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 28rpx;
  padding-top: 56rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #d8ddd8;
  flex-shrink: 0;
}

.user-meta {
  flex: 1;
  min-width: 0;
  padding-top: 4rpx;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.user-name {
  flex: 1;
  min-width: 0;
  font-size: 36rpx;
  font-weight: 700;
  color: #0f1f16;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-school {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  max-width: 78%;
  height: 44rpx;
  padding: 0 16rpx 0 20rpx;
  border-radius: 0 0 18rpx 0;
  background: rgba(255, 107, 26, 0.12);
  border-right: 1rpx solid rgba(255, 107, 26, 0.2);
  border-bottom: 1rpx solid rgba(255, 107, 26, 0.2);
  box-sizing: border-box;
}

.user-school-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  border-radius: 6rpx;
  background: #ffffff;
}

.user-school-text {
  min-width: 0;
  font-size: 20rpx;
  font-weight: 600;
  color: #ff6b1a;
  line-height: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-follow {
  flex-shrink: 0;
  min-width: 112rpx;
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: 26rpx;
  background: #FF6B1A;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  box-sizing: border-box;
}

.user-follow--on {
  background: #eef1ec;
  color: #5c6b60;
}

.user-follow--busy {
  opacity: 0.6;
  pointer-events: none;
}

.user-id {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5c6b60;
  line-height: 1.35;
}

.user-region {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8a968c;
  line-height: 1.35;
}

.user-bio {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #5c6b60;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  word-break: break-word;
}

.user-bio--muted {
  color: #a3aea6;
}

.user-stats-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 20rpx 16rpx 20rpx 8rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.user-stats {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.user-stats-bar--with-actions .user-stats {
  flex: 1;
  min-width: 0;
}

.user-stat {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  position: relative;
}

.user-stat + .user-stat::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 36rpx;
  background: #d8ddd8;
}

.user-stat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f1f16;
  line-height: 1.2;
}

.user-stat-label {
  font-size: 22rpx;
  color: #8a968c;
  line-height: 1.3;
}

.user-message {
  flex-shrink: 0;
  min-height: 56rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  background: #eef1ec;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.user-message-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.user-message-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #5c6b60;
  line-height: 1;
  white-space: nowrap;
}

.user-section-title {
  margin: 20rpx 32rpx 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f1f16;
}
